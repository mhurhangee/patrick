{
	"name": "patrick",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@11.5.2",
	"scripts": {
		"predev": "node scripts/ensure-editor-built.mjs",
		"dev": "pnpm --filter frontend --filter api --parallel dev",
		"predev:desktop": "node scripts/ensure-editor-built.mjs",
		"dev:desktop": "pnpm --filter desktop dev",
		"dev:site": "pnpm --filter site dev",
		"build:editor": "pnpm --filter @eigenpal/docx-editor-react run build",
		"test": "bun test",
		"gen:docs": "bun scripts/gen-patrick-docs.ts",
		"pretypecheck": "node scripts/ensure-editor-built.mjs",
		"typecheck": "pnpm -r --parallel --if-present typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"knip": "knip",
		"check": "pnpm typecheck && pnpm lint:fix && pnpm knip"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"knip": "^6.19.0",
		"typescript": "^6.0.3"
	}
}
