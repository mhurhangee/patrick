{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PatrickOS",
  "version": "0.1.0",
  "identifier": "com.patrickos.desktop",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter frontend dev",
    "beforeBuildCommand": "pnpm --filter frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "PatrickOS",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/api"],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
