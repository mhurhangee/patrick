{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"lib": ["ES2023", "DOM"],
		"types": ["vite/client"],
		// Off here only because this app compiles the vendored editor's source
		// (consumed from ./src), which predates the flag. The base keeps it ON, so
		// shared/ui/law/benchmarking and the app's non-editor code stay protected.
		"noUncheckedIndexedAccess": false,
		"jsx": "react-jsx",
		"moduleDetection": "force",
		"allowImportingTsExtensions": true,
		"erasableSyntaxOnly": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src"]
}
