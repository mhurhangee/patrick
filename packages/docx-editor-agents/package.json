{
  "name": "@eigenpal/docx-editor-agents",
  "version": "1.9.0",
  "description": "Agent SDK and chat UI for the DOCX editor — framework-agnostic bridge, MCP server, AI SDK adapters, plus React UI",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.mjs",
      "require": "./dist/bridge.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.mjs",
      "require": "./dist/mcp.js"
    },
    "./ai-sdk/server": {
      "types": "./dist/ai-sdk/server.d.ts",
      "import": "./dist/ai-sdk/server.mjs",
      "require": "./dist/ai-sdk/server.js"
    },
    "./ai-sdk/react": {
      "types": "./dist/ai-sdk/react.d.ts",
      "import": "./dist/ai-sdk/react.mjs",
      "require": "./dist/ai-sdk/react.js"
    }
  },
  "typesVersions": {
    "*": {
      "bridge": [
        "./dist/bridge.d.ts"
      ],
      "server": [
        "./dist/server.d.ts"
      ],
      "react": [
        "./dist/react.d.ts"
      ],
      "mcp": [
        "./dist/mcp.d.ts"
      ],
      "ai-sdk/server": [
        "./dist/ai-sdk/server.d.ts"
      ],
      "ai-sdk/react": [
        "./dist/ai-sdk/react.d.ts"
      ]
    }
  },
  "peerDependencies": {
    "ai": "^5.0.0 || ^6.0.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eigenpal/docx-editor-core": "workspace:*",
    "@types/react": "19.2.17",
    "ai": "^6.0.169",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "docxtemplater": "^3.50.0",
    "jszip": "^3.10.1",
    "pizzip": "^3.1.7",
    "xml-js": "^1.6.11"
  },
  "keywords": [
    "docx",
    "ai",
    "agent",
    "review",
    "track-changes",
    "comments",
    "legal",
    "contract"
  ],
  "author": {
    "name": "Jedr Blaszyk",
    "email": "jedr@eigenpal.com",
    "url": "https://github.com/jedrazb"
  },
  "license": "Apache-2.0"
}
