{
  "name": "@eigenpal/docx-editor-agents",
  "version": "1.9.0",
  "description": "Agent SDK for the DOCX editor — docx tool schemas, the editor-bridge executor, AI SDK server adapter, and the headless DocxReviewer.",
  "sideEffects": false,
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./ai-sdk/server": {
      "types": "./dist/ai-sdk/server.d.ts",
      "import": "./dist/ai-sdk/server.mjs",
      "require": "./dist/ai-sdk/server.js"
    }
  },
  "typesVersions": {
    "*": {
      "server": [
        "./dist/server.d.ts"
      ],
      "react": [
        "./dist/react.d.ts"
      ],
      "ai-sdk/server": [
        "./dist/ai-sdk/server.d.ts"
      ]
    }
  },
  "peerDependencies": {
    "ai": "^6.0.0 || ^7.0.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eigenpal/docx-editor-core": "workspace:*",
    "@types/bun": "^1.0.0",
    "@types/react": "19.2.17",
    "ai": "^7.0.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "docxtemplater": "^3.50.0",
    "jszip": "^3.10.1",
    "pizzip": "^3.1.7",
    "xml-js": "^1.6.11"
  },
  "keywords": [
    "docx",
    "ai",
    "agent",
    "review",
    "track-changes",
    "comments",
    "legal",
    "contract"
  ],
  "author": {
    "name": "Jedr Blaszyk",
    "email": "jedr@eigenpal.com",
    "url": "https://github.com/jedrazb"
  },
  "license": "Apache-2.0"
}
